{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user account details and permissions.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "editor", "viewer"] },
        "bio": { "type": "string" },
        "title": { "type": "string" },
        "department": { "type": "string" },
        "location": { "type": "string" },
        "updatedAt": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "email", "displayName", "role", "updatedAt", "createdAt"]
    },
    "ActivityLog": {
      "title": "Activity Log",
      "description": "Records administrative actions and system updates.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "timestamp": { "type": "number" },
        "metadata": { "type": "object" }
      },
      "required": ["id", "userId", "userName", "action", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Main user records."
    },
    "/activityLogs/{logId}": {
      "schema": "ActivityLog",
      "description": "System-wide activity trail."
    }
  }
}
