rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function existingData() {
      return resource.data;
    }

    function incomingData() {
      return request.resource.data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- User Profiles ---
    match /users/{userId} {
      function isValidUserProfile(data) {
        return data.keys().hasAll(['uid', 'email', 'displayName', 'role', 'updatedAt', 'createdAt'])
          && data.keys().size() >= 6 && data.keys().size() <= 15
          && data.uid == userId
          && data.email is string && data.email.size() <= 256
          && data.displayName is string && data.displayName.size() <= 128
          && data.role in ['admin', 'editor', 'viewer']
          && (data.updatedAt is number || data.updatedAt is timestamp)
          && (data.createdAt is number || data.createdAt is timestamp);
      }

      allow read: if isSignedIn();

      allow create: if isOwner(userId) 
        && isValidUserProfile(incomingData())
        && (
          incomingData().role == 'viewer' || 
          (incomingData().role == 'admin' && incomingData().email == 'mbagayoko@unfpa.org')
        )
        && (incomingData().createdAt is number)
        && (incomingData().updatedAt is number);

      allow update: if isSignedIn() && (
        // Admin can update everything
        (isAdmin() && isValidUserProfile(incomingData())) ||
        // Owner can update everything EXCEPT role and uid
        (isOwner(userId) 
          && isValidUserProfile(incomingData())
          && (incomingData().role == existingData().role || (incomingData().role == 'admin' && incomingData().email == 'mbagayoko@unfpa.org'))
          && incomingData().uid == existingData().uid
          && incomingData().createdAt == existingData().createdAt
          && (incomingData().updatedAt is number))
      );

      allow delete: if isAdmin();
    }

    // --- Activity Logs ---
    match /activityLogs/{logId} {
      function isValidLog(data, isUpdate) {
        return data.keys().hasAll(['userId', 'userName', 'action', 'timestamp'])
          && data.keys().size() >= 4 && data.keys().size() <= 8
          && (isUpdate ? data.id == logId : true)
          && data.userId == request.auth.uid
          && data.timestamp is number;
      }

      allow read: if isAdmin();
      allow create: if isSignedIn() && isValidLog(incomingData(), false);
      allow update: if isSignedIn() && isValidLog(incomingData(), true);
    }

    // --- Test Connection ---
    match /test/connection {
      allow read: if true;
    }
  }
}
