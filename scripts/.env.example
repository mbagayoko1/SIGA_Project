# Server-side credentials for the data scripts ONLY (db-seed, ingest --db).
# The service-role key BYPASSES Row-Level Security — never expose it to the
# client bundle and never commit the real scripts/.env (gitignored via .env*).
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"
